  "Afip": {
    "Wsaa": {
      "Enabled": false,
      "BaseUrl": "https://wsaahomo.afip.gov.ar/ws/services/LoginCms",
      "CertificatePath": "",
      "CertificatePassword": "",
      "Service": "wsfe",
      "CacheMinutes": 60,
      "RefreshSkewMinutes": 5,
      "GenerationOffsetMinutes": 10,
      "ExpirationMinutes": 720
    },
    "Wsfe": {
      "Enabled": false,
      "BaseUrl": "https://wswhomo.afip.gov.ar/wsfev1/service.asmx",
      "Token": "",
      "Sign": "",
      "TokenExpiration": "",
      "Cuit": "",
